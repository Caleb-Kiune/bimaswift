// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Quote {
  id               String   @id @default(uuid())
  idempotencyKey   String   @unique
  vehicleValue     Int
  yom              Int
  coverType        String
  insurerId        String
  selectedRiderIds String[]
  createdAt        DateTime @default(now())
  userId           String
}

model MotorCommercialQuote {
  id               String   @id @default(uuid())
  userId           String   // Links the quote to the Clerk user who generated it
  
  // The Insurer
  insurerId        String
  insurerName      String   

  // The Request (Risk Details)
  coverType        String   
  usageType        String   
  tonnage          Float
  sumInsured       Float?
  isFleet          Boolean
  includePLL       Boolean
  passengerCount   Int?
  selectedRiders   String[] 

  // The Result (Premium Breakdown)
  basicPremium     Float
  pllCharge        Float
  riderPremiums    Float
  levies           Float
  stampDuty        Float
  totalPremium     Float

  // Metadata
  createdAt        DateTime @default(now())
}