// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Quote {
  id               String   @id @default(uuid())
  idempotencyKey   String   @unique
  vehicleValue     Int
  yom              Int
  coverType        String
  insurerId        String
  selectedRiderIds String[]
  createdAt        DateTime @default(now())
  userId           String
}

model MotorCommercialQuote {
  id               String   @id @default(uuid())
  idempotencyKey   String   @unique
  userId           String
  insurerId        String
  insurerName      String 

  // Request Context
  coverType        String   
  usageType        String   
  tonnage          Float
  sumInsured       Float?
  isFleet          Boolean
  includePLL       Boolean
  passengerCount   Int?
  selectedRiders   String[] 

  // Premium Totals
  basicPremium     Float
  pllCharge        Float
  riderPremiums    Float
  levies           Float    
  stampDuty        Float
  totalPremium     Float

  // Transparency Details (The "Math Story")
  basePremiumDetails Json?   
  riderDetails       Json?   
  levyDetails        Json?   
  
  // UX Flags
  floorOverrodeDiscount Boolean @default(false)
  fleetDiscountApplied  Boolean @default(false)

  createdAt        DateTime @default(now())
}



